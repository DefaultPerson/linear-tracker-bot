# Linear Bot configuration (.env format)

# Telegram
TELEGRAM_TOKEN=8139381867:XXXX

# Legacy single chat (DEPRECATED - use CHATS instead)
TELEGRAM_GROUP_ID=-1000000000000

# Multi-chat configuration (many-to-many teams to chats)
# Format: name1:chat_id1:TEAM1,TEAM2;name2:chat_id2:TEAM3
# Example: main:-1002188528272:HMC,HMO;alerts:-1001234567890:TRA
# CHATS=main:-1002188528272:HMC,HMO

# DM notifications for allowed users (comma-separated telegram user IDs)
# ALLOWED_USERS=384823683,427972598

# Mapping telegram user ID to Linear assignee name (for DM by assignee)
# Format: tg_id1:LinearName1,tg_id2:LinearName2
# USER_ASSIGNEE_MAP=384823683:Alex Semenuk,427972598:Yuriy Yurka

# Team owners - receive ALL notifications for their team (by team, not assignee)
# Format: TEAM1:user_id1,user_id2;TEAM2:user_id3
# TEAM_DM_MAP=BLUE:384823683;RED:427972598

# Linear
LINEAR_API_KEY=your_linear_api_key_here
# Comma-separated team keys (e.g., HMC,HMO). Optional
LINEAR_TEAM_KEYS=HMC,HMO
# Mapping Linear display name -> telegram username (no @). Comma-separated pairs NAME:@tg without @
# Example: John Doe=john,Jane Roe=jane
LINEAR_ASSIGNEE_MAP=clear_account=clear_account

# Schedule/timezone
SCHEDULE_TZ=Europe/Moscow
SCHEDULE_DAILY_TIME=08:00
SCHEDULE_WEEKLY_CRON=0 0 * * MON
SCHEDULE_POLL_INTERVAL=60

# Storage
DATA_DIR=bots/linear-bot/data
